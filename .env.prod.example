# host39 — production environment
# cp .env.prod.example .env.prod — then fill in every blank value
# Generate strong secrets: openssl rand -hex 64

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

FRONTEND_URL=https://agentcards.host39.org

# ── Web (baked into Next.js bundle at build time) ─────────────────────────────
# Same domain — Caddy routes /auth/* and /cards/* to the backend
NEXT_PUBLIC_HOST39_API_URL=https://agentcards.host39.org
