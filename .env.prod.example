# host39 — production environment
# cp .env.prod.example .env.prod — then fill in every blank value
# Generate strong secrets: openssl rand -hex 64

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Frontend origin (used for CORS + email links)
FRONTEND_URL=https://host39.org

# ── AgentStatus (agentstatus.dev) reliability monitoring ──────────────────────
# Shared out-of-band by AgentStatus. Leave blank to keep monitoring disabled.
NANDA_WEBHOOK_SECRET=
NANDA_STATUS_API_TOKEN=
AGENTSTATUS_API_BASE_URL=https://api.rora.carmel.so
AGENTSTATUS_POLL_INTERVAL_MS=120000

# ── Web (baked into Next.js bundle at build time) ─────────────────────────────
# API is served under the same domain as the frontend — no CORS
NEXT_PUBLIC_HOST39_API_URL=https://host39.org
# Public card serving domain — where agent card JSON is served
NEXT_PUBLIC_HOST39_PUBLIC_BASE_URL=https://agentcards.host39.org
